# База данных PostgreSQL
DATABASE_URL=postgres://inspection:secret@localhost:5432/inspection_db?sslmode=disable

# JWT секрет для подписи токенов авторизации
# ОБЯЗАТЕЛЕН в production (GIN_MODE=release). Без него приложение не запустится.
# Минимум 32 символа. Сгенерировать: openssl rand -base64 32
JWT_SECRET=

# Яндекс Диск (опционально)
YADISK_TOKEN=your_yadisk_token_here
YADISK_ROOT=disk:/inspection-app

# Redis (опционально — асинхронная загрузка фото)
# Без этой переменной фото загружаются синхронно (старое поведение)
REDIS_URL=redis://localhost:6379
